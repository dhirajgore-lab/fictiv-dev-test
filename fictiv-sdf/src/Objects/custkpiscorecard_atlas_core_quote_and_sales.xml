<kpiscorecard scriptid="custkpiscorecard_atlas_core_quote_and_sales">
  <description>Scorecards are an intelligent tool allows users to monitor key information in real-time, from senior management down to the performance of teams and individuals. It consolidates information into useful information that gives users the big picture, enabling managers to make critical decisions at the right time.</description>
  <name>Quote &amp; Sales</name>
  <useperiods>F</useperiods>
  <custom>
    <kpi1>[scriptid=customsearch_atlas_events_rpt]</kpi1>
    <kpi10></kpi10>
    <kpi2>[scriptid=customsearch_atlas_phonecalls_rpt]</kpi2>
    <kpi3>[scriptid=customsearch_atlas_tasks_rpt]</kpi3>
    <kpi4>[scriptid=customsearch_atlas_expired_quotes]</kpi4>
    <kpi5>[scriptid=customsearch_atlas_openquotes_rpt]</kpi5>
    <kpi6></kpi6>
    <kpi7></kpi7>
    <kpi8></kpi8>
    <kpi9></kpi9>
  </custom>
  <audience>
    <allemployees>F</allemployees>
    <allpartners>F</allpartners>
    <allroles>T</allroles>
    <audslctrole></audslctrole>
  </audience>
  <kpis>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>NEWLEADS</kpi>
      <label>Leads</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>NEWLEADSGROSS</kpi>
      <label>New Leads</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>OPPORTUNITIESRANGE</kpi>
      <label># Open Opps</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>ESTIMATESRANGE</kpi>
      <label># Open Quotes</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM5</kpi>
      <label>Value of Open Quotes</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM4</kpi>
      <label>Expired Quotes</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM</kpi>
      <label>Events</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM2</kpi>
      <label>Phone Calls</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM3</kpi>
      <label>Tasks</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>BOOKINGS</kpi>
      <label>Sales</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>TOTALORDERS</kpi>
      <label>Total Orders</label>
    </kpi>
    <kpi>
      <formula>{BOOKINGS}/({CUSTOM}+{CUSTOM2}+{CUSTOM3})</formula>
      <hidden>F</hidden>
      <kpi>FORMULACURRENCY</kpi>
      <label>Sales Per Activity</label>
      <lessismore>F</lessismore>
    </kpi>
    <kpi>
      <formula>{CUSTOM}+{CUSTOM2}+{CUSTOM3}</formula>
      <hidden>F</hidden>
      <kpi>FORMULANUMERIC</kpi>
      <label>Total Activities</label>
      <lessismore>F</lessismore>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM6</kpi>
      <label># of Line Item</label>
    </kpi>
  </kpis>
