<kpiscorecard scriptid="custkpiscorecard_atlas_core_employee">
  <description>Scorecards are an intelligent tool allows users to monitor key information in real-time, from senior management down to the performance of teams and individuals. It consolidates information into useful information that gives users the big picture, enabling managers to make critical decisions at the right time.</description>
  <name>Employee</name>
  <useperiods>F</useperiods>
  <custom>
    <kpi1>[scriptid=customsearch_atlas_new_employees_rpt]</kpi1>
    <kpi10></kpi10>
    <kpi2>[scriptid=customsearch_atlas_employee_churn_rpt]</kpi2>
    <kpi3></kpi3>
    <kpi4>[scriptid=customsearch_atlas_tax_int_dep_exp_rpt]</kpi4>
    <kpi5></kpi5>
    <kpi6>[scriptid=customsearch_atlas_equity_trans_kpi]</kpi6>
    <kpi7>[scriptid=customsearch_atlas_hire_emp_kpi]</kpi7>
    <kpi8>[scriptid=customsearch_atlas_term_emp_kpi]</kpi8>
    <kpi9>[scriptid=customsearch_atlas_total_emp_count]</kpi9>
  </custom>
  <audience>
    <allemployees>F</allemployees>
    <allpartners>F</allpartners>
    <allroles>T</allroles>
    <audslctrole></audslctrole>
  </audience>
  <kpis>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>EMPLOYEES</kpi>
      <label>Employees</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM7</kpi>
      <label>Hired Employees</label>
    </kpi>
    <kpi>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <hidden>F</hidden>
      <invertcomparison>F</invertcomparison>
      <kpi>CUSTOM8</kpi>
      <label>Terminated Employees</label>
    </kpi>
    <kpi>
      <formula>{CUSTOM7}-{CUSTOM8}</formula>
      <hidden>F</hidden>
      <kpi>FORMULANUMERIC</kpi>
      <label>Employee Churn</label>
      <lessismore>F</lessismore>
    </kpi>
    <kpi>
      <formula>{REVENUE}/{EMPLOYEES}</formula>
      <hidden>F</hidden>
      <kpi>FORMULACURRENCY</kpi>
      <label>Revenue Per Employee</label>
      <lessismore>F</lessismore>
    </kpi>
  </kpis>
  <ranges>
    <range>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <invertcomparison>F</invertcomparison>
      <label>Today</label>
      <range>TODAY</range>
    </range>
    <range>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <invertcomparison>F</invertcomparison>
      <label>This WTD</label>
      <range>THIS_WEEK_TO_DATE</range>
    </range>
    <range>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <invertcomparison>F</invertcomparison>
      <label>This MTD</label>
      <range>THIS_MONTH_TO_DATE</range>
    </range>
    <range>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <invertcomparison>F</invertcomparison>
      <label>Last MTD</label>
      <range>LAST_MONTH_TO_DATE</range>
    </range>
    <range>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <invertcomparison>F</invertcomparison>
      <label>This FQTD</label>
      <range>THIS_FISCAL_QUARTER_TO_DATE</range>
    </range>
    <range>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <invertcomparison>F</invertcomparison>
      <label>Last FQTD</label>
      <range>LAST_FISCAL_QUARTER_TO_DATE</range>
    </range>
    <range>
      <comparevalueto></comparevalueto>
      <comparewithprevious>F</comparewithprevious>
      <comparisontype></comparisontype>
      <invertcomparison>F</invertcomparison>
      <label>This FYTD</label>
      <range>THIS_FISCAL_YEAR_TO_DATE</range>
    </range>
    <range>
